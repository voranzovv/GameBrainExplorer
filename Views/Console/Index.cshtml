@model List<GameBrainExplorer.Models.GameConsole>
<!-- Optional: Bootstrap CDN for quick styling -->
<link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
  rel="stylesheet"/>

<style>
  .game-card {
    border-radius: 16px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease;
    overflow: hidden;
    background: #fff;
  }

  .game-card:hover {
    transform: scale(1.03);
  }

  .game-img {
    height: 200px;
    object-fit: cover;
    width: 100%;
  }

  .badge-adult {
    background: crimson;
  }

  .rating {
    font-weight: bold;
    color: #f39c12;
  }
</style>

<div class="container mt-4">
  <h1 class="mb-4 text-center">🎮 Game Explorer</h1>

  <div class="row g-4">
    @foreach (var console in Model)
    {
      <div class="col-md-4">
        <div class="game-card">
          <!-- Image -->
          <img src="@console.Image" class="game-img" alt="Game Image"/>

          <div class="p-3">
            <!-- Title + Year -->
            <h4>
              @console.Name
              <small class="text-muted">(@(console.Year ?? 0))</small>
            </h4>

            <!-- Genre -->
            <p class="text-secondary mb-1">🎯 @console.Genre</p>

            <!-- Rating -->
            <p class="rating">
              ⭐ @(console.Rating?.Mean ?? 0) / 5
              <span class="text-muted">
                (@(console.Rating?.Count ?? 0) reviews)
              </span
              >
            </p>

            <!-- Adult Only -->
            @if (console.Adult_Only)
            {
              <span class="badge badge-adult">18+</span>
            }

            <!-- Description -->
            <p class="mt-2">
              @(console.Short_Description?.Length > 100 ? console.Short_Description.Substring(0, 100) + "..." : console.Short_Description)
            </p>

            <!-- Link -->
            <a
              href="@console.Link"
              target="_blank"
              class="btn btn-primary btn-sm">
              View Details
            </a
            >
          </div>
        </div>
      </div>
    }
  </div>
</div>
